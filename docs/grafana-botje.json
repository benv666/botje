{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "botje",
  "uid": "botje",
  "tags": ["botje", "irc"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "IRC",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "botje_connected", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "connected", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Modules",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "botje_modules", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Goroutines",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "go_goroutines", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Heap in use",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "go_memstats_heap_alloc_bytes", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Storage op latency (avg)",
      "description": "Feeds the markov blob decision: the ns=markov put is the whole-trie rewrite.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(botje_storage_op_seconds_sum[5m]) / rate(botje_storage_op_seconds_count[5m])",
          "legendFormat": "{{ns}} {{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Storage ops",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "sum by (ns, op) (rate(botje_storage_op_seconds_count[5m]))",
          "legendFormat": "{{ns}} {{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Flood queue depth",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [
        { "expr": "botje_flood_queue_depth", "legendFormat": "{{channel}}", "refId": "A" },
        { "expr": "botje_work_backlog", "legendFormat": "work backlog", "refId": "B" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Hook calls",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (module) (rate(botje_hook_calls_total[5m]))",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Hook time",
      "description": "Dispatcher seconds spent per module per second: >0.1 sustained means a module is hogging the single dispatcher goroutine.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "sum by (module) (rate(botje_hook_duration_seconds_sum[5m]))",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Memory",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes", "legendFormat": "heap alloc", "refId": "A" },
        { "expr": "go_memstats_heap_sys_bytes", "legendFormat": "heap sys", "refId": "B" },
        { "expr": "go_memstats_sys_bytes", "legendFormat": "total sys", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Fetch duration (avg)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(botje_fetch_duration_seconds_sum[10m]) / rate(botje_fetch_duration_seconds_count[10m])",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Fetch errors",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "sum by (host) (increase(botje_fetch_errors_total[30m]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Reconnects / admin logins",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "targets": [
        { "expr": "increase(botje_reconnects_total[1h])", "legendFormat": "reconnects (1h)", "refId": "A" },
        { "expr": "sum by (result) (increase(botje_admin_logins_total[1h]))", "legendFormat": "login {{result}} (1h)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
