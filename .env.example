# Copy to .env and fill in. .env is gitignored: server addresses and
# secrets live here, never in tracked files.

# --- IRC (used by the keeper)
# Required: the ircd to connect to, host:port.
BOTJE_IRC_ADDR=irc.example.com:6669
BOTJE_IRC_TLS=true
# Optional /etc/hosts pin for the ircd FQDN, "fqdn:ip". Leave unset for
# normal DNS.
#BOTJE_EXTRA_HOST=irc.example.com:10.0.0.2

# --- bot identity (used by the core)
BOTJE_NETWORK=junerules
BOTJE_NICK=Meretrix
BOTJE_CHANNELS=#testing
# For cutover: BOTJE_NICK=hoer and the live channel list, AFTER stopping
# the perl hoer and migrating a fresh data dump.

# --- keeper image pin
# The keeper is deliberately not rebuilt by `docker compose build`; it
# runs this pinned tag so core upgrades never recreate it (that would
# drop the IRC session). Build one with `make keeper-image`.
BOTJE_KEEPER_IMAGE=go-botje:keeper-00000000

# --- storage
POSTGRES_PASSWORD=change-me
# Named volume by default; set an absolute host path for a bind mount,
# e.g. /docker/botje-go/mounts/postgres/var/lib/postgresql/data
#BOTJE_PG_DATA=

# --- admin
# Telnet superuser bootstrap: name:bcrypt-hash.
# Generate the hash with: docker compose run --rm core hash <password>
# Leave empty to bootstrap users later with `botje adduser`.
BOTJE_SUPERUSER=

# LLM keys etc. are set at runtime via the telnet conf command
# (conf llm_openai_key=..., conf llm_aws_key=..., etc.), not here.
