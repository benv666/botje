# Copy to .env and fill in. .env is gitignored.

# Postgres password for the storage sidecar (required).
POSTGRES_PASSWORD=change-me

# Telnet admin superuser bootstrap: name:bcrypt-hash.
# Generate the hash with: docker compose run --rm botje hash <password>
# Leave empty to bootstrap users later with `botje adduser`.
BOTJE_SUPERUSER=

# LLM keys etc. are set at runtime via the telnet conf command
# (conf llm_openai_key=..., conf llm_aws_key=..., etc.), not here.
